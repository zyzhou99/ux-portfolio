---
interface Props {
  title: string;
  type: string;
  description: string;
  tags: string[];
  href?: string;
  image?: string;
  imageAlt?: string;
  index?: number;
  featured?: boolean;
}

const {
  title,
  type,
  description,
  tags,
  href = "#",
  image,
  imageAlt = `${title} project preview`,
  index = 0,
  featured = false,
} = Astro.props;

const number = String(index + 1).padStart(2, "0");
---

<article
  class:list={[
    "group overflow-hidden rounded-[2rem] border border-[#1f1f1f]/10 bg-white shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-2xl hover:shadow-[#d66f3f]/10",
    featured ? "md:grid md:grid-cols-[1.05fr_0.95fr]" : "",
  ]}
>
  <a href={href} class="block overflow-hidden">
    <div
      class:list={[
        "relative flex items-end overflow-hidden bg-gradient-to-br from-[#f7d8c1] via-[#f7efe1] to-[#e9d7b8] p-6",
        featured ? "min-h-[360px] md:h-full" : "min-h-[290px]",
      ]}
    >
      {image ? (
        <img
          src={image}
          alt={imageAlt}
          class="absolute inset-0 h-full w-full object-cover object-center transition-transform duration-700 group-hover:scale-105"
          loading="lazy"
        />
      ) : (
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_20%,rgba(255,255,255,0.75),transparent_30%),linear-gradient(135deg,#f7d8c1,#f7efe1,#e9d7b8)]"></div>
      )}

      <div class="absolute inset-0 bg-gradient-to-t from-black/25 via-black/0 to-white/10"></div>

      <div class="relative flex h-20 w-20 items-center justify-center rounded-full bg-white/80 text-xl font-semibold text-[#1f1f1f] shadow-sm transition-transform duration-300 group-hover:scale-105 md:h-24 md:w-24 md:text-2xl">
        {number}
      </div>
    </div>
  </a>

  <div class="flex flex-col p-6 md:p-8">
    <p class="mb-3 text-sm font-medium text-[#d66f3f]">
      {type}
    </p>

    <h3 class="text-3xl font-semibold tracking-[-0.03em]">
      <a href={href} class="transition-colors hover:text-[#d66f3f]">
        {title}
      </a>
    </h3>

    <p class="mt-4 leading-7 text-[#5f5a54]">
      {description}
    </p>

    <div class="mt-6 flex flex-wrap gap-2">
      {tags.map((tag) => (
        <span class="rounded-full border border-[#1f1f1f]/10 px-3 py-1 text-xs text-[#5f5a54]">
          {tag}
        </span>
      ))}
    </div>

    <a
      href={href}
      class="mt-8 inline-flex w-fit text-sm font-semibold text-[#1f1f1f] transition-colors hover:text-[#d66f3f]"
    >
      View case study →
    </a>
  </div>
</article>