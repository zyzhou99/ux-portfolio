    transform: translate3d(-50%, -50%, 0) scale(0.5);
    transform-origin: center;
    will-change: transform, opacity;
    animation-name: face-firework;
    animation-duration: 950ms;
    animation-timing-function: cubic-bezier(0.16, 0.78, 0.26, 1);
    animation-fill-mode: forwards;
  }

  @keyframes face-firework {
    0% {
      opacity: 0;
      transform: translate3d(-50%, -50%, 0) scale(0.35) rotate(0deg);
    }

    12% {
      opacity: 1;
    }

    55% {
      opacity: 1;
      transform:
        translate3d(
          calc(-50% + var(--burst-x)),
          calc(-50% + var(--burst-y)),
          0
        )
        scale(1.12)
        rotate(var(--rotate-mid));
    }

    100% {
      opacity: 0;
      transform:
        translate3d(
          calc(-50% + var(--burst-x-final)),
          calc(-50% + var(--burst-y-final)),
          0
        )
        scale(0.9)
        rotate(var(--rotate-final));
    }
  }

  @media (min-width: 768px) {
