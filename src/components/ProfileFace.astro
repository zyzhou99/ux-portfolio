<script is:inline>
  const stage = document.querySelector("[data-profile-face]");
  const profile = stage?.querySelector(".profile");
  const confettiLayer = stage?.querySelector(".face-confetti");

  if (stage && profile) {
    const eyes = profile.querySelectorAll(".eye");
    const faces = profile.querySelectorAll(".face");

    let animationFrame = null;
    let latestEvent = null;
    let activeTrigger = null;

    const moveFace = () => {
      if (!latestEvent || profile.classList.contains("is-smiling")) {
        animationFrame = null;
        return;
      }

      const event = latestEvent;

      const eyeX = `${(event.clientX * 100) / window.innerWidth / 70}%`;
      const eyeY = `${(event.clientY * 100) / window.innerHeight / 36}%`;

      eyes.forEach((part) => {
        part.style.left = eyeX;
        part.style.top = eyeY;
        part.style.transform = `translate(-${eyeX}, ${eyeY})`;
      });

      const faceX = `${(event.clientX * 100) / window.innerWidth / 140}%`;
      const faceY = `${(event.clientY * 100) / window.innerHeight / 60}%`;

      faces.forEach((part) => {
        part.style.left = faceX;
        part.style.top = faceY;
        part.style.transform = `translate(-${faceX}, ${faceY})`;
      });

      animationFrame = null;
    };

    window.addEventListener("pointermove", (event) => {
      latestEvent = event;

      if (!animationFrame) {
        animationFrame = requestAnimationFrame(moveFace);
      }
    });

    const resetFace = () => {
      profile.classList.remove("is-smiling", "is-look-left", "is-look-right", "is-look-down");

      eyes.forEach((part) => {
        part.style.left = "";
        part.style.top = "";
        part.style.transform = "";
      });

      faces.forEach((part) => {
        part.style.left = "";
        part.style.top = "";
        part.style.transform = "";
      });
    };

    const getClickableTrigger = (target) => {
      return target.closest(
        "[data-face-expression], a, button, [role='button'], input[type='button'], input[type='submit']"
      );
    };

    const launchConfetti = () => {
      if (!confettiLayer) return;

      confettiLayer.innerHTML = "";

      const items = ["🌟", "💻", "🎨", "💡", "📐", "✏️"];

      const bursts = [
        {
          burstX: "-260px",
          burstY: "-210px",
          burstXFinal: "-310px",
          burstYFinal: "-250px",
          rotateMid: "-28deg",
          rotateFinal: "80deg",
        },
        {
          burstX: "-150px",
          burstY: "-295px",
          burstXFinal: "-180px",
          burstYFinal: "-345px",
          rotateMid: "20deg",
          rotateFinal: "110deg",
        },
        {
          burstX: "-20px",
          burstY: "-330px",
          burstXFinal: "-20px",
          burstYFinal: "-390px",
          rotateMid: "-12deg",
          rotateFinal: "95deg",
        },
        {
          burstX: "150px",
          burstY: "-295px",
          burstXFinal: "180px",
          burstYFinal: "-345px",
          rotateMid: "28deg",
          rotateFinal: "-110deg",
        },
        {
          burstX: "260px",
          burstY: "-210px",
          burstXFinal: "310px",
          burstYFinal: "-250px",
          rotateMid: "-20deg",
          rotateFinal: "95deg",
        },
        {
          burstX: "40px",
          burstY: "-260px",
          burstXFinal: "70px",
          burstYFinal: "-315px",
          rotateMid: "18deg",
          rotateFinal: "-90deg",
        },
      ];

      bursts.forEach((burst, index) => {
        const piece = document.createElement("span");
        piece.className = "confetti-piece";
        piece.textContent = items[index % items.length];

        piece.style.setProperty("--burst-x", burst.burstX);
        piece.style.setProperty("--burst-y", burst.burstY);
        piece.style.setProperty("--burst-x-final", burst.burstXFinal);
        piece.style.setProperty("--burst-y-final", burst.burstYFinal);
        piece.style.setProperty("--rotate-mid", burst.rotateMid);
        piece.style.setProperty("--rotate-final", burst.rotateFinal);
        piece.style.animationDelay = `${index * 45}ms`;

        confettiLayer.appendChild(piece);
      });

      window.setTimeout(() => {
        confettiLayer.innerHTML = "";
      }, 1100);
    };

    document.addEventListener("pointerover", (event) => {
      const trigger = getClickableTrigger(event.target);
      if (!trigger) return;

      if (activeTrigger === trigger) return;
      activeTrigger = trigger;

      resetFace();

      const expression = trigger.getAttribute("data-face-expression");

      profile.classList.add("is-smiling");

      if (expression === "left") {
        profile.classList.add("is-look-left");
      } else if (expression === "right") {
        profile.classList.add("is-look-right");
      } else if (expression === "down") {
        profile.classList.add("is-look-down");
      }

      launchConfetti();
    });

    document.addEventListener("pointerout", (event) => {
      const trigger = getClickableTrigger(event.target);
      if (!trigger) return;

      if (trigger.contains(event.relatedTarget)) return;

      if (activeTrigger === trigger) {
        activeTrigger = null;
        resetFace();
      }
    });
  }
</script>