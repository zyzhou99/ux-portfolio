---
interface PlaygroundImage {
  src: string;
  alt: string;
}

interface Props {
  images: PlaygroundImage[];
}

const { images } = Astro.props;

const firstRow = images.slice(0, 4);
const secondRow = images.slice(4, 8);

const firstRowLoop = [...firstRow, ...firstRow];
const secondRowLoop = [...secondRow, ...secondRow];
---

<div class="playground-carousel" aria-label="Playground image carousel">
  <div class="playground-carousel__fade playground-carousel__fade--left"></div>
  <div class="playground-carousel__fade playground-carousel__fade--right"></div>

  <div class="playground-carousel__row">
    <div class="playground-carousel__track playground-carousel__track--left">
      {firstRowLoop.map((item) => (
        <article class="playground-carousel__item">
          <img
            src={item.src}
            alt={item.alt}
            class="playground-carousel__image"
            loading="lazy"
          />
        </article>
      ))}
    </div>
  </div>

  <div class="playground-carousel__row">
    <div class="playground-carousel__track playground-carousel__track--right">
      {secondRowLoop.map((item) => (
        <article class="playground-carousel__item">
          <img
            src={item.src}
            alt={item.alt}
            class="playground-carousel__image"
            loading="lazy"
          />
        </article>
      ))}
    </div>
  </div>
</div>

<style>
  .playground-carousel {
    --card-width: clamp(220px, 19vw, 320px);
    --gap: 1rem;
    --start-offset: -80px;

    position: relative;
    display: grid;
    gap: var(--gap);
    width: 100%;
    overflow: hidden;
    padding: 0.25rem 0;
  }

  .playground-carousel__row {
    width: 100%;
    overflow: hidden;
  }

  .playground-carousel__track {
    display: flex;
    width: max-content;
    gap: var(--gap);
    will-change: transform;
  }

  .playground-carousel__track--left {
    animation: playground-scroll-left 28s linear infinite;
  }

  .playground-carousel__track--right {
    animation: playground-scroll-right 32s linear infinite;
  }

  .playground-carousel:hover .playground-carousel__track {
    animation-play-state: paused;
  }

  .playground-carousel__item {
    flex: 0 0 var(--card-width);
    width: var(--card-width);
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border-radius: 1.25rem;
    border: 1px solid rgba(31, 31, 31, 0.1);
    background: rgba(255, 255, 255, 0.72);
    box-shadow: 0 1px 2px rgba(31, 31, 31, 0.04);
  }

  .playground-carousel__image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 500ms ease;
  }

  .playground-carousel__item:hover .playground-carousel__image {
    transform: scale(1.06);
  }

  .playground-carousel__fade {
    pointer-events: none;
    position: absolute;
    top: 0;
    bottom: 0;
    z-index: 2;
    width: 4rem;
  }

  .playground-carousel__fade--left {
    left: 0;
    background: linear-gradient(to right, #f7efe1, rgba(247, 239, 225, 0));
  }

  .playground-carousel__fade--right {
    right: 0;
    background: linear-gradient(to left, #f7efe1, rgba(247, 239, 225, 0));
  }

  @keyframes playground-scroll-left {
    from {
      transform: translateX(var(--start-offset));
    }

    to {
      transform: translateX(calc(-50% + var(--start-offset)));
    }
  }

  @keyframes playground-scroll-right {
    from {
      transform: translateX(calc(-50% + var(--start-offset)));
    }

    to {
      transform: translateX(var(--start-offset));
    }
  }

  @media (min-width: 1280px) {
    .playground-carousel {
      --card-width: clamp(240px, 18vw, 340px);
      --start-offset: -90px;
    }
  }

  @media (max-width: 767px) {
    .playground-carousel {
      --card-width: clamp(210px, 72vw, 300px);
      --start-offset: -60px;
    }
  }
</style>