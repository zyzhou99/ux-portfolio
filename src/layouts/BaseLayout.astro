---
import "../styles/global.css";
import { withBase } from "../utils/paths";

interface Props {
  title?: string;
  description?: string;
  lang?: "en" | "zh";
}

const {
  title = "Ziyan Zhou | UI/UX Portfolio",
  description = "Ziyan Zhou is a UI/UX designer and frontend-oriented product builder creating accessible, delightful digital experiences.",
  lang = "en",
} = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>

    <link rel="icon" type="image/svg+xml" href={withBase("favicon.ico")} />
  </head>

  <body>
    <slot />
  </body>
</html>